                    _ => prop.Name
                };
                var val = prop.Value.ValueKind switch
                {
                    System.Text.Json.JsonValueKind.True  => "Ano",
                    System.Text.Json.JsonValueKind.False => "Ne",
                    _ => prop.Value.ToString()
                };
                // Přeložíme hodnoty
                val = val switch
                {
                    "gas"           => "Plyn",
                    "electric"      => "Elektřina",
                    "solid_fuel"    => "Tuhá paliva",
