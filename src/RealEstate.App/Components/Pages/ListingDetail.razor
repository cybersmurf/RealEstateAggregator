    // Upload fotek z prohlídky
    private IReadOnlyList<IBrowserFile> _driveInspectionFiles = [];
    private IReadOnlyList<IBrowserFile> _oneDriveInspectionFiles = [];
    private bool _uploadingDrivePhotos = false;
