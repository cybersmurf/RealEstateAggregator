    private async Task RunAiTextAsync(string url, string successMsg, string failMsg)
    {
        _aiTextLoading = true;
        StateHasChanged();
        try
        {
            // Batch=1 zpracuje první inzerát – ale my chceme konkrétní listing.
            // Workaround: dočasně update přes dedicated endpoint if listing not yet processed,
            // jinak jednoduše zavoláme batch a refreshneme detail (listing bude první ve frontě
            // pokud je ještě nezpracovaný)
            var response = await Http.PostAsync(url, null, _cts.Token);
            if (response.IsSuccessStatusCode)
